{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Frontend Port",
  "version": "0.1.0",
  "identifier": "com.local.frontend-port",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Frontend Port",
        "width": 380,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/sing-box"]
  }
}
