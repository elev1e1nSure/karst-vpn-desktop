{
  "name": "karst-vpn",
  "private": true,
  "version": "1.2.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
